{
  "name": "ado-ai-review-bot",
  "version": "0.4.0",
  "description": "Azure DevOps Server 2022 AI code review bot: Service Hooks webhook + Codex CLI deep review + PR comment QA",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "bash scripts/package.sh",
    "package:docker": "bash scripts/package.sh --docker",
    "package:win": "powershell -ExecutionPolicy Bypass -File scripts/package.ps1"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.10.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
