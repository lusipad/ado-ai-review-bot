# ---- 服务 ----
HOST=0.0.0.0
PORT=3000
# mirror / worktree / sqlite 存放目录
DATA_DIR=./data

# ---- Azure DevOps Server ----
# collection URL（到 collection 一级，不含项目名）
ADO_URL=https://ado.corp.local/DefaultCollection
# 服务账号（ai-review-bot）的 PAT，需要 Code Read & Write 权限
ADO_PAT=
# Service Hook 订阅里配置的密钥（basic auth 密码，或自定义 x-webhook-secret 头）
WEBHOOK_SECRET=

# ---- bot 身份（用于过滤自触发 + @mention 匹配） ----
# 服务账号的 identity GUID（见 README「获取 bot 账号 GUID」）
BOT_ACCOUNT_ID=
BOT_DISPLAY_NAME=ai-review-bot

# ---- 调度 ----
# push 防抖窗口（毫秒），默认 3 分钟
DEBOUNCE_MS=180000
# review 全局并发（瓶颈是内网模型吞吐）
REVIEW_CONCURRENCY=2
# @bot 问答并发（独立通道，不排在长 review 后）
QA_CONCURRENCY=2

# ---- Codex CLI ----
CODEX_BIN=codex
CODEX_TIMEOUT_MS=900000
CODEX_SANDBOX=read-only
# 额外命令行参数（按部署机 codex 版本调整），空格分隔
CODEX_EXTRA_ARGS=
# 内网模型 API key（codex config.toml 里 env_key 指向的变量名）
INTRANET_API_KEY=

# ---- review 行为 ----
MAX_INLINE_COMMENTS=10
MAX_CHANGED_FILES=50
PROMPTS_DIR=./prompts
# 按仓库覆盖配置的 JSON 文件路径（可选，见 README）
# BOT_CONFIG_FILE=./bot-config.json

# ---- IM 通知（可选，两者可同时启用） ----
# RocketChat Incoming Webhook 完整 URL
ROCKETCHAT_WEBHOOK_URL=
# 企业微信群机器人 key（或完整 webhook URL）
WECOM_WEBHOOK_KEY=
# 推送哪些事件，逗号分隔：review_completed,must_fix_found,job_failed
NOTIFY_EVENTS=review_completed,must_fix_found,job_failed
