# ============================================================
#  必填（只有这 4 项，其余全部可留默认）
# ============================================================

# ADO collection URL（到 collection 一级，不含项目名）
ADO_URL=https://ado.corp.local/DefaultCollection
# bot 服务账号（如 ai-review-bot）的 PAT，权限：Code Read & Write
ADO_PAT=
# 自定义一个随机字符串，配置 Service Hooks 订阅时填同一个值
WEBHOOK_SECRET=
# 内网模型 API key（codex config.toml 里 env_key 指向的变量名）
INTRANET_API_KEY=

# ============================================================
#  可选（以下均有默认值，按需取消注释）
# ============================================================

# ---- 服务 ----
#HOST=0.0.0.0
#PORT=3000
# mirror / worktree / sqlite 存放目录
#DATA_DIR=./data
# 优雅停机时等待在跑任务收尾的最长时间（毫秒），超时任务由下次启动自动补跑
#SHUTDOWN_GRACE_MS=120000

# ---- bot 身份 ----
# bot 账号 identity GUID：留空则启动时自动获取（PAT 属于 bot 账号本身即可）
#BOT_ACCOUNT_ID=
# @提及 bot 用的显示名，需与 ADO 账号显示名一致
#BOT_DISPLAY_NAME=ai-review-bot

# ---- 调度 ----
# push 防抖窗口（毫秒），默认 3 分钟
#DEBOUNCE_MS=180000
# review 全局并发（瓶颈是内网模型吞吐）
#REVIEW_CONCURRENCY=2
# @bot 问答并发（独立通道，不排在长 review 后）
#QA_CONCURRENCY=2

# ---- Codex CLI ----
#CODEX_BIN=codex
# 单次 review 超时（毫秒），默认 15 分钟
#CODEX_TIMEOUT_MS=900000
#CODEX_SANDBOX=read-only
# 额外命令行参数（按部署机 codex 版本调整），空格分隔
#CODEX_EXTRA_ARGS=
# 非超时失败（网络/模型 API 抖动）的自动重试次数
#CODEX_RETRIES=1
# 多模型交叉 review：profile 列表，逗号分隔，支持 engine 前缀：
#   deepseek        = 默认引擎（codex）的 config.toml profile
#   claude          = Claude Code 默认模型
#   claude:opus     = Claude Code 指定模型
#   codex:deepseek  = 显式指定 codex 引擎
# 每个 profile 独立深入 review 后合并结果；注意实际引擎并发 = REVIEW_CONCURRENCY × profile 数
#REVIEW_PROFILES=default
# 示例：codex 主模型 + Claude Code 交叉 review
#REVIEW_PROFILES=default,claude

# ---- Claude Code 引擎（可选） ----
# 无 engine 前缀的 profile 用哪个引擎：codex（默认）| claude
#REVIEW_ENGINE=codex
# claude 可执行文件；Windows npm 安装时指向真实 exe：
#   %APPDATA%\npm\node_modules\@anthropic-ai\claude-code\bin\claude.exe
#CLAUDE_BIN=claude
# 传给 claude 的额外参数，空格分隔（如 --fallback-model sonnet）
#CLAUDE_EXTRA_ARGS=

# ---- 沟通风格 ----
# 沟通风格卡：决定评论/问答/修复说明的语气。默认是「资深友善同事」卡（见 README），
# 想换风格就整段重写（.ai-review.yml 的 persona 字段可按仓库覆盖）
#PERSONA=

# ---- review 行为 ----
# 每轮行内评论上限，超出归并进总评
#MAX_INLINE_COMMENTS=10
# 变更文件数超过阈值时降级为摘要模式
#MAX_CHANGED_FILES=50
#PROMPTS_DIR=./prompts
# 按仓库覆盖配置的 JSON 文件路径（见 README「Review 行为定制」）
#BOT_CONFIG_FILE=./bot-config.json
# 质疑 pass：review 后追加一轮独立复核过滤假阳性（多一次模型调用），false 关闭
#CHALLENGE_ENABLED=true
# /fix 命令全局默认开关（默认关；按仓库开用 BOT_CONFIG_FILE 的 repoOverrides.<仓库>.allowFix，
# 安全原因不认 PR 分支里的 .ai-review.yml）
#FIX_ENABLED=false
# /fix 改动规模护栏：超限直接放弃不 push
#FIX_MAX_FILES=10
#FIX_MAX_LINES=300
# 仓库知识库：首次 review 后生成架构摘要注入后续 review/问答，false 关闭
#KNOWLEDGE_ENABLED=true
# 知识库刷新周期（天）
#KNOWLEDGE_TTL_DAYS=14
# dream：每周日 03:00 用模型整理各仓库长期记忆（合并重复/淘汰过时/归纳高频问题），false 关闭
#DREAM_ENABLED=true

# ---- 度量 ----
# 每周一 09:00（服务器时区）向 IM 渠道推送度量周报
#WEEKLY_REPORT_ENABLED=false

# 通知静默时段（如 21-9 表示 21:00~次日 09:00）：期间通知积压、结束时按仓库汇总一条发出；
# review 本身照常执行，只是不吵人。不配则不静默
#QUIET_HOURS=

# 触发筛选：这些变更不算需要 review 的变更，PR 变更全部命中时直接跳过（不烧模型）。
# 默认已含常见图片/字体/二进制扩展名与各语言 lockfile，配置即整体覆盖默认值
#REVIEW_IGNORE_EXTENSIONS=.png,.jpg,.svg,...
#REVIEW_IGNORE_FILENAMES=package-lock.json,yarn.lock,...

# ---- IM 通知（可同时启用多个） ----
# RocketChat Incoming Webhook 完整 URL
#ROCKETCHAT_WEBHOOK_URL=
# RocketChat 双向问答：Outgoing Webhook 的 token（不配则该端点关闭）
#ROCKETCHAT_OUTGOING_TOKEN=
# RC REST 身份（自由问答/线程回复/自动建讨论需要；bot 用户 + Personal Access Token）
#ROCKETCHAT_URL=http://rc-host:3000
#ROCKETCHAT_BOT_USER_ID=
#ROCKETCHAT_BOT_TOKEN=
# 企业微信群机器人 key（或完整 webhook URL）
#WECOM_WEBHOOK_KEY=
# 推送哪些事件，逗号分隔：review_completed,must_fix_found,job_failed
#NOTIFY_EVENTS=review_completed,must_fix_found,job_failed
